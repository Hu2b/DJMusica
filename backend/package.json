{
  "name": "djmusica-backend",
  "version": "0.1.0",
  "private": true,
  "description": "DJMusica backend: Game Engine, Auth Service, Answer Matcher, Track Picker, Playlist Sync Service, Statistics Service.",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "dev": "echo 'TODO: server nog te bouwen, zie bouwplan.md Fase 4' && exit 0",
    "build": "echo 'TODO: build-stap nog te bouwen, zie bouwplan.md Fase 3' && exit 0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0"
  },
  "jest": {
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "reports",
          "outputName": "testrapport-junit.xml",
          "suiteName": "DJMusica backend-tests",
          "classNameTemplate": "{filepath}",
          "titleTemplate": "{title}"
        }
      ],
      [
        "jest-html-reporter",
        {
          "outputPath": "reports/testrapport.html",
          "pageTitle": "DJMusica - testrapport",
          "includeConsoleLog": true,
          "includeFailureMsg": true,
          "includeSuiteFailure": true,
          "dateFormat": "yyyy-mm-dd HH:MM:ss"
        }
      ]
    ]
  }
}
