# Voorbeeld-omgevingsvariabelen voor de backend.
# Kopieer dit bestand naar ".env" en vul echte waarden in.
# LET OP: ".env" staat in .gitignore en mag NOOIT gecommit worden — het bevat geheimen.

# --- E-mail (Resend) ---
# De API-sleutel van je Resend-account. Aanmaken in het Resend-dashboard.
# Deze hoort in productie in GitHub Secrets / de serveromgeving, niet in de code.
RESEND_API_KEY=

# Afzenderadres van de mails. Vereist een in Resend geverifieerd domein.
RESEND_FROM="DJMusica <noreply@djmusica.fun>"

# Basis-URL van de app; wordt gebruikt voor de links in de e-mails.
APP_BASE_URL=https://djmusica.fun
